# ── Dev Sandbox Configuration ────────────────────────────────────────

# code-server password (shown on the login page)
PASSWORD=changeme

# Port for VS Code web UI
SANDBOX_PORT=8531
DIND_PORT=1000"

# Preview port range — ports exposed from DinD containers to the host.
# When you run  docker run -p 3000:3000 myapp  inside the sandbox,
# port 3000 is accessible at  http://<host-ip>:3000
# Increase PREVIEW_END if you need more ports.
PREVIEW_START=2000
PREVIEW_END=2020

# AI tool API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
